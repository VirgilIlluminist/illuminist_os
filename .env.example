# ═══════════════════════════════════════════════════════════
# ILLUMINIST OS — Environment Configuration
#
# CARA PAKAI:
#   cp .env.example .env   → lalu isi nilainya
#
# ⚠ KEAMANAN:
#   - Jangan pernah commit file .env ke GitHub
#   - API Key AI HANYA di server-side (tanpa prefix VITE_)
#   - Frontend TIDAK BOLEH pegang API key apapun
#   - Semua AI call sudah diproxy melalui backend Express
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────
# Ambil dari: supabase.com → Project → Settings → API
# VITE_ prefix agar Vite inject ke frontend (hanya URL & anon key)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key HANYA untuk backend — jangan expose ke frontend!
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Providers (server-side only, tanpa prefix VITE_) ───
# ⚠ TIDAK ADA VITE_ di sini — key ini hanya dibaca oleh Express
# Frontend hanya hit /api/ai/chat — backend yang inject key ini
#
# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=
# OpenAI GPT — https://platform.openai.com
OPENAI_API_KEY=
# Anthropic Claude — https://console.anthropic.com
CLAUDE_API_KEY=
# OpenRouter (200+ model) — https://openrouter.ai
OPENROUTER_API_KEY=
# Default provider dipakai kalau semua tersedia
AI_DEFAULT_PROVIDER=gemini

# ── Rate Limiting ─────────────────────────────────────────
# Per user/IP dalam 1 menit (default: 100 req API, 20 req AI)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20

# ── Security ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-ini-dengan-string-random-minimal-64-karakter
ENCRYPTION_KEY=ganti-ini-dengan-tepat-32-karakter!!

# ── App ───────────────────────────────────────────────────
APP_NAME=ILLUMINIST OS
APP_VERSION=1.0.0

# ── E2E Tests ────────────────────────────────────────────────────────────────
E2E_EMAIL=illuministproject@gmail.com
E2E_PASSWORD=your_supabase_password_here
