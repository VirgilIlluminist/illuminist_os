# ═══════════════════════════════════════════════════════════
# NEVAEH AI OS v12 — Environment Configuration
# 
# CARA PAKAI:
# 1. Duplikat file ini
# 2. Beri nama: .env (hapus kata "example")
# 3. Isi nilai yang diperlukan
# 4. Jangan pernah commit file .env ke GitHub!
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase (Database & Auth) ────────────────────────────
# Ambil dari: supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Hanya untuk backend/server — JANGAN isi di frontend!
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Providers (isi minimal 1) ──────────────────────────
# Google Gemini — Gratis: https://aistudio.google.com
GEMINI_API_KEY=
# OpenAI GPT: https://platform.openai.com
OPENAI_API_KEY=
# Anthropic Claude: https://console.anthropic.com
CLAUDE_API_KEY=
# OpenRouter (200+ model): https://openrouter.ai
OPENROUTER_API_KEY=

# ── Security ─────────────────────────────────────────────
JWT_SECRET=ganti-ini-dengan-string-random-minimal-32-karakter
ENCRYPTION_KEY=ganti-ini-dengan-tepat-32-karakter!!
